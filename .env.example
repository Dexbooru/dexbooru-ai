# server settings
SERVER_NAME=dexbooru-ai
SERVER_PORT=8001
ENVIRONMENT=development

# external service settings

# RabbitMQ settings
AMQP_URL=amqp://guest:supersecret@localhost:5672
PRIMARY_EXCHANGE_NAME=ai_events

# Qdrant settings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# Gemini settings
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_EMBEDDING_MODEL_NAME=gemini-embedding-2-preview
GEMINI_OUTPUT_DIMENSIONS=1536

# Image settings
CDN_BASE_URL=http://localhost:4566
IMAGE_RESIZE_WIDTH=512
IMAGE_RESIZE_HEIGHT=512

# ML (Danbooru tag-rating predictor)
DANBOORU_TAG_RATING_SKOPS_PATH=models/danbooru_tag_rating_predictor.skops
SPACY_ENGLISH_MODEL=en_core_web_md
